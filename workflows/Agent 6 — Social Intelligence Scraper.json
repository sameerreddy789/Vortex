    {
      "parameters": {
        "jsCode": "const PRODUCT = 'ApexIntel';\n// We use a single combined search to avoid overwriting the 'latest' document twice\nconst query = `https://www.reddit.com/r/SaaS/search/?q=${PRODUCT}&sort=new`;\nreturn [{ json: { jina_url: `https://r.jina.ai/${query}`, platform: 'reddit' } }];"
      },
      "id": "b19083f0-c604-4f75-87fe-315011ecae12",
      "name": "Build Jina URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        256,
        0
      ]
    },
    {
      "parameters": {
        "url": "={{$json.jina_url}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
