              "value": "text/plain"
            }
          ]
        },
        "options": {}
      },
      "id": "086c309b-bdb3-48fc-816d-c7bc544a7587",
      "name": "Jina Fetch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
